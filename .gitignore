# build artifacts
*.o
*.mod
*.exe
.DS_Store

# Cowan build outputs (regenerated by build/build.sh and build/make_cfp.sh)
build/bin/
build/cfp/
build/src/RCGPAR.F

# Vendored Cowan package: keep source + docs + scripts; exclude archives & Windows binaries
cowan_nist/*.zip
cowan_nist/extracted/**/*.exe
cowan_nist/extracted/**/*.EXE
cowan_nist/extracted/**/*.dll

# LaTeX aux files (keep .tex source and .pdf output)
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz

# Worked-example run outputs (regenerate with work/run_sn7plus.sh)
work/sn7plus/
# illustrative orbital fig superseded by sn7p_orbitals.pdf
docs/figs/orbitals.pdf

# Mg I warm-up run outputs (regenerate with work/run_mg1.sh); keep the deck
work/mg1/*
!work/mg1/in36

# Bob Kurucz reference decks/outputs fetched from kurucz.harvard.edu/atoms
# (large; fetch with tools/fetch_kurucz_ref.sh rather than committing)
kurucz_ref/

# Full-basis Mg I run outputs (regenerate with work/run_mg1_full.sh; in36 via
# tools/gen_in36.py)
work/mg1_full/

# Scratch RCG run dirs (regenerable binary decks: FOR07x/ING11/OUTG11/...)
work/mg1_cond/
work/mg1_probe/
work/mg1_irel/
work/mg1_corrf/
# Parallel-Jacobian worker dirs (transient; auto-created/removed per fit run)
work/mg1_full_w*/
